{
    "book_id": "default_vedic",
    "description": "Standard patterns for classical Vedic astrology texts",
    "parsing_strategy": {
        "verse_pattern": "॥\\s*(\\d+(?:\\s*[-–]\\s*\\d+)?)\\s*॥",
        "section_pattern": "^(\\d+)\\.\\s+([A-Z][^\\n]+)",
        "semantic_markers": [
            "Notes?\\s*:",
            "Specifically\\s*:",
            "Conversely\\s*:",
            "For example\\s*:",
            "Result\\s*:",
            "Interpretations?\\s*:"
        ],
        "sanskrit_detection": true
    },
    "technical_limits": {
        "max_tokens": 700,
        "chunk_overlap": 50
    }
}