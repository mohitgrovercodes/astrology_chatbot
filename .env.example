## =========================
## Core API Configuration
## =========================

# FastAPI server
api_host=0.0.0.0
api_port=8000
DEBUG=false
LOG_LEVEL=INFO

# CORS (restrict in production, e.g. https://your-frontend.com)
ALLOWED_ORIGINS=["*"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

## =========================
## Authentication / Security
## =========================

# Comma-separated list of valid API keys clients must send as X-API-Key header
VALID_API_KEYS=your-api-key-1,your-api-key-2

# Shared secret for internal service-to-service calls
internal_service_secret=change-me-in-production

## =========================
## LLM Provider
## =========================

# Provider: "openai" (production) | "free" (local Ollama)
LLM_PROVIDER=openai
default_llm_provider=openai

# Primary LLM (RAG synthesis, predictions, context analysis)
default_llm_model=gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# Fast LLM (intent classification, safety check, follow-up generation)
fast_llm_provider=openai
fast_llm_model=gpt-4o-mini

## =========================
## OpenAI
## =========================

# REQUIRED when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Embeddings (used for ChromaDB ingestion + semantic search + SemanticRouter)
openai_embedding_model=text-embedding-3-large
embedding_dimensions=3072

## =========================
## Ollama (free/local mode)
## =========================

# REQUIRED when LLM_PROVIDER=free
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
# Models pulled via: ollama pull llama3.2:3b && ollama pull llama3.2:1b

## =========================
## Redis Session Store
## =========================

# REQUIRED — session store for profiles, history, chart cache, dasha cache
redis_host=localhost
redis_port=6379
redis_password=

# Session TTL in hours; 0 = permanent (recommended for user profiles)
SESSION_EXPIRY_HOURS=0

## =========================
## ChromaDB Vector Database
## =========================

# Path to ChromaDB persistent storage (must contain pre-ingested Vedic texts)
chroma_persist_dir=./data/vectordb

## =========================
## Conversation / Runtime
## =========================

# Number of recent messages included in every LLM prompt
conversation_context_window=20

# After this many messages, regenerate the rolling conversation summary
conversation_summary_threshold=20

# Hours before transit data (daily-moving planets) is considered stale
transit_refresh_hours=24

# Days before Dasha period cache is considered stale
dasha_refresh_days=30

## =========================
## Response Style Validator
## Thresholds on a 1–10 scale
## =========================

# Minimum "human warmth" score; below this triggers a style rewrite
style_min_human_warmth_score=7

# Minimum "authentic astrologer voice" score
style_min_authentic_astrologer_voice_score=7

# Maximum allowed "repetition risk" score; above this triggers a style rewrite
style_max_repetition_risk_score=4

## =========================
## Hugging Face / Reranker
## =========================

# Set true to avoid HuggingFace hub calls (uses cached cross-encoder model)
hf_offline_mode=false

# Seconds to wait for HuggingFace model download before timing out
hf_timeout=10

## =========================
## External Astrology API (optional)
## =========================

# Only needed if using src/integrations/astrology_api/client.py
astro_username=
astro_password=
