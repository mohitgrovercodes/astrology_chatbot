## =========================
## Core API Configuration
## =========================

# FastAPI
api_host=0.0.0.0
api_port=8000

# OpenAI
OPENAI_API_KEY=your-openai-api-key
default_llm_provider=openai
default_llm_model=gpt-4o-mini
openai_embedding_model=text-embedding-3-large
embedding_dimensions=3072

# Auth
VALID_API_KEYS=your-api-key
internal_service_secret=change-me

# Redis
redis_host=localhost
redis_port=6379
redis_password=

## =========================
## Conversation / Runtime
## =========================
conversation_context_window=20
conversation_summary_threshold=20
transit_refresh_hours=24
dasha_refresh_days=30

## =========================
## Style Validator Thresholds
## 1-10 scale
## =========================
style_min_human_warmth_score=7
style_min_authentic_astrologer_voice_score=7
style_max_repetition_risk_score=4

