# NakshatraAI API - Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your values

# ----------------------------------------------------------------------------
# API CONFIGURATION
# ----------------------------------------------------------------------------
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
# Comma-separated list of API keys for public endpoints
VALID_API_KEYS=your-api-key-1,your-api-key-2

# Shared secret for internal service authentication (backend integration)
INTERNAL_SERVICE_SECRET=super-secret-internal-key-change-me

# ----------------------------------------------------------------------------
# REDIS SESSION MANAGEMENT
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
SESSION_EXPIRY_HOURS=24

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=*

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=10

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# MongoDB connection string (optional - set USE_DUMMY_USER_DB=true for testing)
MONGODB_URI=mongodb://localhost:27017/nakshatraai
USE_DUMMY_USER_DB=true

# ----------------------------------------------------------------------------
# LLM PROVIDER - OPTION 1: OpenAI (Recommended)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
FAST_LLM_PROVIDER=openai
FAST_LLM_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# LLM PROVIDER - OPTION 2: Google Cloud (Vertex AI)
# ----------------------------------------------------------------------------
# GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json
# GOOGLE_PROJECT_ID=your-gcp-project-id
# GOOGLE_LOCATION=us-central1
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash-exp

# ----------------------------------------------------------------------------
# LLM PROVIDER - OPTION 3: Ollama (Local)
# ----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2

# ----------------------------------------------------------------------------
# ORCHESTRATOR SETTINGS
# ----------------------------------------------------------------------------
ENABLE_CACHING=true
MAX_CONVERSATION_HISTORY=10

# ----------------------------------------------------------------------------
# THIRD-PARTY ASTROLOGY API (Optional)
# ----------------------------------------------------------------------------
# Configure these to use external API for birth chart calculations
# ASTRO_API_BASE_URL=https://api.astrology-service.com/v1
# ASTRO_API_KEY=your-api-key-here
# ASTRO_API_TIMEOUT=30
# ASTRO_API_CACHE_TTL=3600

# ----------------------------------------------------------------------------
# LEGACY SETTINGS (Optional - for backward compatibility)
# ----------------------------------------------------------------------------
ASTRO_USERNAME=
ASTRO_PASSWORD=
