    {
      "rule_id": "VR001",
      "rule_name": "Lagna (Ascendant) must be determined from the rising sign",
      "category": "general",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "Before any astrological analysis or prediction can commence",
        "calculation": "Identify the Rashi (sign) that is rising on the eastern horizon at the precise time and location of birth. This Rashi becomes the Lagna.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": true,
      "impact_if_violated": "The entire astrological chart and any subsequent analysis will be fundamentally incorrect or impossible to construct, rendering all predictions invalid.",
