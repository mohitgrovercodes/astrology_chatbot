    {
      "rule_id": "VR1121",
      "rule_name": "Arudha Pada Calculation Exception (7th House)",
      "category": "general",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When the standard calculation of an Arudha Pada (AP) for a house (H) results in the AP falling in the 7th house from H.",
        "calculation": "1. Identify the house (H) for which the Arudha Pada is being calculated. 2. Determine the lord (L) of house H. 3. Count the number of houses from H to L (inclusive, if L is in H). 4. Count the same number of houses from L to find the initial Arudha Pada. 5. If this initial Arudha Pada is the 7th house from H, then this rule applies. 6. The corrected Arudha Pada for H must then be taken as the 4th house from H.",
        "threshold": null,
        "comparison": null
