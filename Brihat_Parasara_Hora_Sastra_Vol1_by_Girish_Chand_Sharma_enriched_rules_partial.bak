      "lagna_specific_rules": null,
      "classical_reference": "Brihat Parasara Hora Sastra Vol1 by Girish Chand Sharma, Verse 1-2",
      "chapter": null,
      "verse_range": "1-2",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule establishes a fundamental hierarchy for assessing the strength of planetary relationships as defined in the provided text. The specific interpretation of each relationship type (e.g., Sahavasashtha as conjunction) should be based on broader classical understanding, but the order of strength is explicitly given by the text's sequence."
