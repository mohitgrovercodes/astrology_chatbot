    {
      "rule_id": "VR162",
      "rule_name": "Panchadha Maitri (Five-Fold Planetary Relationship) Determination",
      "category": "planetary_state",
      "severity": "critical",
      "check_order": 5,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When assessing the interactive strength and nature of two planets in a birth chart.",
        "calculation": "Determine the Naisargika (Natural) relationship and the Tatkalika (Temporary) relationship between any two planets. Combine these two relationships to establish the Panchadha Maitri (Five-Fold Relationship) as follows:\n1.  **Ati Mitra (Extreme Friend)**: If a planet is naturally friendly AND temporarily friendly to another.\n2.  **Mitra (Friend)**: If a planet is naturally friendly AND temporarily neutral, OR naturally neutral AND temporarily friendly to another.\n3.  **Shatru (Enemy)**: If a planet is naturally inimical AND temporarily neutral, OR naturally neutral AND temporarily inimical to another.\n4.  **Ati Shatru (Extreme Enemy)**: If a planet is naturally inimical AND temporarily inimical to another.\n(Note: The 'Sama' (Neutral) relationship, where both are neutral, is implied in the five-fold system but not explicitly detailed in this specific verse for combination rules.)",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Incorrect assessment of planetary interactions, leading to erroneous predictions regarding planetary strength, benefic/malefic nature, and event outcomes. This foundational relationship impacts all subsequent analyses.",
      "impact_percentage": 80,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "BPHS 57-58",
      "chapter": null,
      "verse_range": "57-58",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule defines the method for determining the five-fold planetary relationship (Panchadha Maitri) by combining Naisargika (Natural) and Tatkalika (Temporary) relationships. The text explicitly describes the combinations leading to Ati Mitra, Mitra, Shatru, and Ati Shatru."
    },
