    {
      "rule_id": "VR1766",
      "rule_name": "Mandatory Determination of Planetary Shayanaadi Avasthas",
      "category": "planetary_state",
      "severity": "critical",
      "check_order": 5,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "To accurately assess the inherent state, activity level, and behavioral disposition of any planet in a horoscope, its Shayanaadi Avastha must be determined.",
        "calculation": "The serial number of the Nakshatra (star) in which the planet is situated is to be multiplied by the serial number of the planet; the product is to be multiplied by the number of the Navamsha and in the product are to be added the number of the Nakshatra(star) at the time of birth, of the Ishtaghati, and of the sign in the Ascendant. The resultant so arrived at is to be divided by 12 and the remainder should be understood as the number of the avastha of the planet in order (Shayana, Upaveshana, Netrapani, Prakashana, Gamana, Agamana, Sabhavastha Agama, Bhojana, Nrityalipsa, Kautuka and Nidra).",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Leads to a fundamental misinterpretation of a planet's inherent nature and its capacity to deliver results, rendering subsequent analysis potentially inaccurate.",
      "impact_percentage": 70,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "BPHS 30-37",
      "chapter": "30",
      "verse_range": "30-37",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule mandates the calculation and determination of the Shayanaadi Avasthas (sleeping and waking states) for each planet, as described in the text, which are crucial for understanding planetary behavior and strength."
    },
    {
      "rule_id": "VR1767",
      "rule_name": "Mandatory Determination of Planetary Drishti, Cheshta, or Vicheshta",
      "category": "planetary_state",
      "severity": "critical",
      "check_order": 6,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "After calculating the Shayanaadi Avastha of a planet, its mode of action (Drishti, Cheshta, or Vicheshta) must be determined to further refine the understanding of its expression.",
        "calculation": "The remainder from the Avastha calculation (or the serial number of the Avastha) is to be multiplied by the remainder itself. In the product is to be added the number of the first letter of the name and then it is to be divided by 12. The remainder thereof is to be added with the constant planetary additaments (Sun 5, Moon 2, Mars 2, Mercury 3, Jupiter 5, Venus 3, Saturn 3, Rahu 4, Ketu 4) respectively and then the figure so arrived at is to be divided by 3. If the remainder is 1, 2 and 0 it is Drishti, Cheshta and Vicheshta respectively.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Leads to an incomplete or incorrect understanding of how a planet manifests its results, whether through direct action (Drishti), conscious effort (Cheshta), or passive influence (Vicheshta).",
      "impact_percentage": 60,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "BPHS 30-37",
      "chapter": "30",
      "verse_range": "30-37",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule mandates the calculation and determination of whether a planet is in Drishti, Cheshta, or Vicheshta state, which provides a deeper insight into its operational mode, building upon its Avastha."
    },
