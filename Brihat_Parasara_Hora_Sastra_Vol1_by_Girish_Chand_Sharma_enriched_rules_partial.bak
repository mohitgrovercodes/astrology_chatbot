    {
      "rule_id": "VR205",
      "rule_name": "Gulika Position Calculation Method",
      "category": "general",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When Upgrahas, specifically Gulika, are included in the astrological analysis.",
        "calculation": "Divide the duration of the day (sunrise to sunset) into 8 equal parts. Starting from the lord of the day (Sunday=Sun, Monday=Moon, etc.), count sequentially. The 8th part is considered lordless (Nireesha). The part designated as 'Shunya' (empty/zero) is known as Gulika.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": true,
      "impact_if_violated": "Incorrect identification of Gulika's position, leading to erroneous astrological interpretations related to Upgrahas.",
      "impact_percentage": 100,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "BPHS 65.66",
