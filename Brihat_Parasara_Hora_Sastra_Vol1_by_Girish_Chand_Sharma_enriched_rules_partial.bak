      "prediction_stage": "promise",
      "check_logic": {
        "condition": "A planet is situated in a watery sign AND is aspected by an enemy planet AND is NOT aspected by any natural benefic planet.",
        "calculation": "1. Identify if the planet is in a watery sign (Cancer, Scorpio, Pisces).\n2. Determine the natural enemies of the planet in question.\n3. Check if any of these enemy planets cast an aspect on the planet.\n4. Identify natural benefic planets (Jupiter, Venus, waxing Moon, Mercury when associated with benefics).\n5. Check if *none* of these natural benefic planets cast an aspect on the planet.\n6. If all three conditions (watery sign, enemy aspect, no benefic aspect) are met, the planet is in Tṛṣita Avastha.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
