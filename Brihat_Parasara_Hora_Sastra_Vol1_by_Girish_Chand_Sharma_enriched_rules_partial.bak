    {
      "rule_id": "VR123",
      "rule_name": "Determination of Natural Planetary Friends (Naisargika Mitra)",
      "category": "planetary_state",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When assessing the inherent benefic/malefic nature and inter-planetary relationships for any planet.",
        "calculation": "For a given planet (P), identify its Mooltrikona sign. The lords of the 4th, 2nd, 12th, 5th, 9th, and 8th signs from P's Mooltrikona sign are considered Natural Friends (Naisargika Mitra) to P. Additionally, the lord of the sign where P is exalted is also considered a Natural Friend (Naisargika Mitra) to P.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Incorrect assessment of inherent planetary benefic/malefic tendencies and inter-planetary relationships, leading to fundamental errors in chart interpretation and prediction.",
      "impact_percentage": 85,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "BPHS Verse 55",
      "chapter": null,
      "verse_range": "55",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule explicitly defines how to identify natural planetary friends based on Mooltrikona and exaltation signs. The verse implies that other planetary lords are either enemies or neutrals, which is typically elaborated in subsequent verses or standard tables of natural relationships. This is a foundational step for assessing planetary strength and interactions."
    },
