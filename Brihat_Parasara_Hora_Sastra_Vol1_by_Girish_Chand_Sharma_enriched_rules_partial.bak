    {
      "rule_id": "VR397",
      "rule_name": "Correct Shashtyamsha Lord Calculation",
      "category": "general",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When performing astrological analysis that utilizes the Shashtyamsha (D60) divisional chart.",
        "calculation": "The Shashtyamsha lord for a planet is determined by its longitude. Remove full signs. Double the remaining degrees and minutes. Divide this value by 12. The remainder, plus one, indicates the sign whose lord is the Shashtyamsha lord for that planet. (Note: The verse mentions Panchamshamsha (1/45th) with a value of 40' initially, but the calculation described ('द्विग्नमंशाद्यमर्कहृत् । शेषं सैकं च तद्राशेर्भपाः षष्ट्यंशपाः स्मृताः') is the standard method for Shashtyamsha lord determination).",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": true,
      "impact_if_violated": "Incorrect calculation of Shashtyamsha lords will lead to an erroneous D60 chart, rendering any subsequent analysis and predictions based on D60 invalid.",
      "impact_percentage": 100,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Brihat Parasara Hora Sastra Vol1 by Girish Chand Sharma",
      "chapter": null,
      "verse_range": "33",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This verse describes a foundational calculation method for determining the lord of the Shashtyamsha (1/60th divisional chart). While not a direct interpretive rule, the correctness of this calculation is a non-negotiable prerequisite for valid astrological analysis using D60, hence it's framed as a validation rule for the chart's construction itself."
    },
