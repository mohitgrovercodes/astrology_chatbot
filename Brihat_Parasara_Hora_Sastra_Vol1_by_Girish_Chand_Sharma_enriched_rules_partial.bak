    {
      "rule_id": "VR985",
      "rule_name": "Resolution of Conflicting Dual Lordship Results of Equal Strength",
      "category": "general",
      "severity": "critical",
      "check_order": 100,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "A planet has lordship over two signs (dual lordship), and the significations or results associated with these two houses are in direct conflict.",
        "calculation": "1. Identify planets with dual lordship. 2. Determine the significations/results associated with each of the two houses ruled by the planet. 3. Assess if these significations are conflicting. 4. Perform a strength assessment (e.g., using Shadbala, Avasthas, or other classical methods) for the planet's ability to deliver the results of each house. 5. If the conflicting results are found to be of *equal strength*, then both results are considered destroyed or nullified.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Failure to correctly resolve conflicting planetary indications, leading to inaccurate or contradictory predictions regarding the native's life events related to the houses involved. The astrologer might predict both positive and negative outcomes for the same area of life, or fail to see the destruction of both.",
