    {
      "rule_id": "VR750",
      "rule_name": "Ascendant Lord under Rahu-Ketu Axis Influence in Specific Signs causing Fear",
      "category": "karmic_axis",
      "severity": "high",
      "check_order": 100,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "The Ascendant Lord is placed in a sign owned by Mars (Aries, Scorpio) or Mercury (Gemini, Virgo).",
        "calculation": "The Ascendant Lord is simultaneously conjoined with Rahu (Tamas) and aspected by Ketu, OR conjoined with Ketu and aspected by Rahu.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "The native experiences fear (भयम्).",
      "impact_percentage": 70,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Brihat Parasara Hora Sastra Vol1 by Girish Chand Sharma, Verse 11 (Section 6)",
      "chapter": null,
      "verse_range": "11",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "The verse 'स्त्रीभिः शुक्रेण, शशिना वायुना संयुतो यदि । गण्डचाण्डालतो नाथौ तमः केतुयुते भयम्' is interpreted in conjunction with the preceding section heading '6. If the Ascendant Lord is in Mars's signs (Aries and Scorpio) or in Mercury's signs (Gemini and Virgo) and is aspected by'. 'संयुतो यदि' (if conjoined) is taken to refer to the Ascendant Lord. 'तमः केतुयुते' (conjoined with Tamas/Rahu and Ketu) is interpreted as the Ascendant Lord being under the simultaneous influence of the Rahu-Ketu axis (e.g., conjoined with one and aspected by the other, which is a common astrological interpretation for 'conjoined with both' when they are 180 degrees apart). The terms 'स्त्रीभिः' (by women) and 'वायुना' (by Vayu) are ambiguous and not included in the rule due to lack of clear astrological meaning in this context. 'गण्डचाण्डालतो नाथौ' (lords from Ganda-Chandal) is also ambiguous and not directly incorporated into this specific rule due to lack of further context."
    },
