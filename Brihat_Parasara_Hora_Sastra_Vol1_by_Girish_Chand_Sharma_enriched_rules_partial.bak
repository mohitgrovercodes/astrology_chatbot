    {
      "rule_id": "VR278",
      "rule_name": "Planetary Position Adjustment for Rahu, Ketu, and Retrograde Planets",
      "category": "planetary_state",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "all"
