    {
      "rule_id": "VR1275",
      "rule_name": "Jupiter Transit Auspiciousness Nullification (Vedha)",
      "category": "hierarchical_logic",
      "severity": "critical",
      "check_order": 100,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "timing",
      "check_logic": {
        "condition": "When assessing the auspiciousness of Jupiter's transit from Janma Lagna.",
        "calculation": "1. Identify Jupiter's current transit house from Janma Lagna. \n2. If Jupiter is transiting in houses 2, 5, 7, 9, or 11 from Janma Lagna (these are considered auspicious houses for Jupiter's transit as per the text). \n3. Check if any other planet (Gaganachari) is simultaneously transiting in the corresponding Vedha house: \n   - If Jupiter is in transit house 2, the Vedha house is 12. \n   - If Jupiter is in transit house 5, the Vedha house is 4. \n   - If Jupiter is in transit house 7, the Vedha house is 8. \n   - If Jupiter is in transit house 9, the Vedha house is 10. \n   - If Jupiter is in transit house 11, the Vedha house is 3.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "The auspicious effects of Jupiter's transit in the specified house are completely nullified, meaning it will 'not be auspicious' (न हि शुभः).",
      "impact_percentage": 100,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Phaladeepika 7.7",
      "chapter": "7",
      "verse_range": "7",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule is extracted from the last two lines of the verse. The third line 'स्वायधर्मतनयास्तसंस्थितो नाकनायकपुरोहितः शुभः' identifies houses 2, 11, 9, 5, 7 as auspicious for Jupiter's transit. The fourth line 'रिःफरन्ध्रखजलत्रिगैर्यदा विध्यते गगनचारिभिर्न हि' identifies houses 12, 8, 10, 4, 3 as Vedha houses that nullify the auspiciousness if occupied by another planet. The listed Vedha houses perfectly correspond to the standard Vedha pairs for Jupiter's auspicious transit houses (2->12, 11->3, 9->10, 5->4, 7->8)."
    },
