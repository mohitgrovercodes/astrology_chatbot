  "rules": [
    {
      "rule_id": "VR001",
      "rule_name": "House-Body Part Correspondence (Kala Purusha Anga)",
      "category": "table_based_rules",
      "severity": "critical",
      "check_order": 1,
      "applies_to_queries": [
        "health",
        "general"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When analyzing physical body parts, health conditions, or physical appearance related to specific anatomical regions.",
        "calculation": "Identify the house corresponding to the specific body part as per the Kala Purusha Anga concept. The Lagna (1st house) corresponds to the head, 2nd house to the face, 3rd house to the breast, 4th house to the heart, and so on for the 12 houses.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Incorrect diagnosis or analysis of physical health, injuries, or appearance related to specific body parts due to misidentification of the governing house.",
      "impact_percentage": 80,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Phaladeepika 4",
      "chapter": null,
      "verse_range": "4",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule establishes the fundamental mapping of houses to body parts of the Kala Purusha (Cosmic Man). Specific mappings explicitly mentioned in the provided text are: 1st House (Lagna) = Head, 2nd House = Face, 3rd House = Breast, 4th House = Heart. The verse implies this mapping continues for all 12 houses."
    },
