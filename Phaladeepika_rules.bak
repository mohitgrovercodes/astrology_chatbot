      "rule_id": "VR476",
      "rule_name": "Moon's Paksha (Waxing/Waning) Assessment",
      "category": "lunar_consideration",
      "severity": "high",
      "check_order": 1,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "promise",
      "check_logic": {
        "condition": "When assessing the Moon's inherent strength, beneficence, and its general impact on the native's constitution, longevity, and well-being.",
        "calculation": "Determine if the Moon is in Shukla Paksha (waxing) or Krishna Paksha (waning). The Moon is considered waxing from the New Moon (Amavasya) to the Full Moon (Purnima), and waning from the Full Moon to the New Moon. Astrologically, a waxing Moon is generally considered stronger and more benefic. The strength increases from Amavasya to Purnima and decreases from Purnima to Amavasya. A common calculation involves the angular distance between the Sun and Moon: if Moon is 0-180 degrees ahead of the Sun, it is waxing; if 180-360 degrees ahead (or 0-180 degrees behind), it is waning.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Incorrect assessment of Moon's inherent strength and benefic/malefic nature, leading to erroneous predictions regarding health, longevity, wealth, and general well-being, as a waning Moon reverses the positive effects of a waxing Moon.",
      "impact_percentage": 80,
      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Phaladeepika_by_Mantreswara, Verse ५",
      "chapter": null,
      "verse_range": "५",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "The verse explicitly states that if the Moon is waning ('क्षयगते'), the effects are 'quite the reverse' ('विपरीतं') of a waxing Moon, indicating a fundamental change in its nature and strength."
