    {
      "rule_id": "VR1296",
      "rule_name": "Venus Transit Vedha",
      "category": "general",
      "severity": "high",
      "check_order": 11,
      "applies_to_queries": [
        "all"
      ],
      "prediction_stage": "timing",
      "check_logic": {
        "condition": "When assessing the effects of Venus's transit.",
        "calculation": "1. Identify Venus's transit house (from Janma Rashi or Moon Rashi, as per context). 2. Check if Venus is transiting any of the following houses: 1st, 2nd, 3rd, 4th, 5th, 8th, 9th, 11th, 12th. 3. If so, check if any other planet is located in the following houses *relative to Venus's transit position*: 1st (Tanu), 3rd (Sahaja), 5th (Dhi), 6th (Vairi), 7th (Asta), 8th (Nidhana), 9th (Dharma), 10th (Karma), 11th (Labha). 4. If both conditions are met, Vedha occurs.",
        "threshold": null,
        "comparison": null
      },
      "halt_on_failure": false,
      "impact_if_violated": "Venus will give bad effects during its transit.",
