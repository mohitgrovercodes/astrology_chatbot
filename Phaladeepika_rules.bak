      "cancellation_conditions": [],
      "lagna_specific_rules": null,
      "classical_reference": "Phaladeepika, Verse 8",
      "chapter": null,
      "verse_range": "8",
      "depends_on_rules": [],
      "conflicts_with_rules": [],
      "extraction_confidence": 0.8,
      "expert_verified": false,
      "extraction_notes": "This rule combines the English statement about Venus's transit houses that are susceptible to Vedha (1st, 2nd, 3rd, 4th, 5th, 8th 9th, 12th and 11th), and the Sanskrit list of houses (1st, 3rd, 5th, 6th, 7th, 8th, 9th, 10th, 11th from Venus) where Vedha-causing planets can be found. The text does not provide specific pairings for 'corresponding' houses, so this rule applies the Vedha-causing houses generally when Venus is in the susceptible transit houses."
    },
